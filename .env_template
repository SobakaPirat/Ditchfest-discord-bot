# Example of what your .env file should look like

# Ubisoft info
UBI_LOGIN = ""
UBI_PASSWORD = ""
USER_AGENT = ""
CLIENT_ID = ""
CLIENT_SECRET = ""

# Your tm.io id
USER_ID = ""

# Path to the database ("db/database.db" by default)
DATABASE = "db/database.db"

# Discord webhook url
WEBHOOKS_URL = ""

# Dropbox service account credentials
DROPBOX_SAVE = false
DROPBOX_KEY = ""
DROPBOX_SECRET = ""
DROPBOX_TOKEN = ""
DROPBOX_REFRESH_TOKEN = ""

# Nadeo stuff, will be set automatically
NADEO_ACCESS_TOKEN=''
NADEO_REFRESH_TOKEN=''
NADEO_LIVESERVICES_ACCESS_TOKEN=''
NADEO_LIVESERVICES_REFRESH_TOKEN=''
OAUTH_TOKEN=''
OAUTH_EXPIRATION=''
OAUTH_EXPIRES=''
